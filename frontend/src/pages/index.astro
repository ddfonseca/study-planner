---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ThemeToggle from '@/components/landing/ThemeToggle.astro';
import '@/index.css';

const currentYear = new Date().getFullYear();

// Gradient colors for calendar preview
const previewGradientColors: Record<number, string> = {
  0: 'bg-card',
  1: 'bg-stone-100 dark:bg-stone-800',
  2: 'bg-amber-100 dark:bg-amber-900/50',
  3: 'bg-amber-200 dark:bg-amber-800/60',
  4: 'bg-[#c17a5c] dark:bg-[#c17a5c]',
};

const calendarDays = [
  { day: 16, label: 'Mon', intensity: 3, session: 'API', time: '1h30' },
  { day: 17, label: 'Tue', intensity: 2, session: 'Review', time: '45m' },
  { day: 18, label: 'Wed', intensity: 0, session: '', time: '' },
  { day: 19, label: 'Thu', intensity: 4, session: 'Feature', time: '2h', isToday: true },
  { day: 20, label: 'Fri', intensity: 1, session: 'Bugfix', time: '30m' },
  { day: 21, label: 'Sat', intensity: 0, session: '', time: '' },
  { day: 22, label: 'Sun', intensity: 0, session: '', time: '' },
];

const getTextClass = (intensity: number, isToday: boolean) => {
  if (intensity === 4) return 'text-white';
  if (isToday) return 'text-primary';
  if (intensity >= 3) return 'text-foreground';
  return 'text-muted-foreground';
};

const needsLightText = (intensity: number) => intensity === 4;
---

<BaseLayout title="ShipHours - Track your real productive hours">
  <div class="min-h-screen bg-background">

    <!-- Navigation -->
    <header class="border-b border-border bg-card/50 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 sm:h-6 sm:w-6 text-primary">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span class="font-semibold text-base sm:text-lg">ShipHours</span>
        </div>
        <div class="flex items-center gap-1 sm:gap-2">
          <a href="#features" class="hidden sm:flex text-sm text-muted-foreground hover:text-foreground transition-colors px-2 h-8 items-center">
            Features
          </a>
          <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors px-2 h-8 flex items-center">
            Blog
          </a>
          <ThemeToggle />
          <a href="/login">
            <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-8 rounded-md px-3 text-xs sm:text-sm">
              Sign in
            </button>
          </a>
        </div>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="py-10 sm:py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
        <h1 class="animate-on-scroll text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-4 sm:mb-6">
          Track your real productive hours, <span class="text-primary">not just time at a desk</span>
        </h1>
        <p class="animate-on-scroll text-base sm:text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto mb-6 sm:mb-8 px-2">
          ShipHours helps software engineers measure deep work, build focus habits, and stay intentional about where their time goes.
        </p>
        <div class="animate-on-scroll flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center px-4 sm:px-0">
          <a href="/login" class="w-full sm:w-auto">
            <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 rounded-md px-6 w-full sm:w-auto text-sm sm:text-base">
              Start tracking for free
            </button>
          </a>
          <a href="#features" class="w-full sm:w-auto">
            <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 rounded-md px-6 w-full sm:w-auto text-sm sm:text-base">
              Learn more
            </button>
          </a>
        </div>
      </div>
    </section>

    <!-- Calendar Preview Section -->
    <section class="py-8 sm:py-12 md:py-16 bg-muted/30">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <h2 class="animate-on-scroll text-xl sm:text-2xl md:text-3xl font-semibold text-center mb-6 sm:mb-8">
          Visualize your progress
        </h2>
        <div class="animate-on-scroll w-full max-w-4xl mx-auto px-4">
          <div class="grid grid-cols-4 sm:grid-cols-8 gap-2 sm:gap-3">
            {calendarDays.map((d) => {
              const isHighIntensity = d.intensity >= 3;
              const lightText = needsLightText(d.intensity);
              return (
                <div
                  class:list={[
                    'relative rounded-xl p-3 sm:p-4 transition-all border border-border/30',
                    d.isToday && 'ring-2 ring-accent ring-offset-2 ring-offset-background',
                    previewGradientColors[d.intensity],
                  ]}
                >
                  <div class:list={[
                    'text-[10px] sm:text-xs font-medium mb-1',
                    lightText ? 'text-white/80' : isHighIntensity ? 'text-foreground/70' : 'text-muted-foreground'
                  ]}>
                    {d.label}
                  </div>
                  <div class:list={['text-lg sm:text-xl font-bold', getTextClass(d.intensity, !!d.isToday)]}>
                    {d.day}
                  </div>
                  {d.session ? (
                    <div class:list={[
                      'mt-2 text-[10px] sm:text-xs',
                      lightText ? 'text-white/90' : isHighIntensity ? 'text-foreground/80' : 'text-muted-foreground'
                    ]}>
                      <div class="font-medium">{d.session}</div>
                      <div class:list={[
                        'font-semibold',
                        lightText ? 'text-white' : isHighIntensity ? 'text-foreground' : 'text-primary'
                      ]}>{d.time}</div>
                    </div>
                  ) : (
                    <div class:list={[
                      'mt-2 text-[10px] sm:text-xs',
                      lightText ? 'text-white/50' : isHighIntensity ? 'text-foreground/50' : 'text-muted-foreground/50'
                    ]}>
                      —
                    </div>
                  )}
                </div>
              );
            })}
            <!-- Total card -->
            <div class="rounded-xl p-3 sm:p-4 bg-gradient-to-br from-primary/10 to-primary/5 border border-primary/20 shadow-md">
              <div class="text-[10px] sm:text-xs font-medium text-muted-foreground mb-1">Total</div>
              <div class="text-lg sm:text-xl font-bold text-primary">5h 45m</div>
              <div class="mt-2">
                <div class="h-1.5 bg-primary/20 rounded-full overflow-hidden">
                  <div class="h-full w-[60%] bg-primary rounded-full"></div>
                </div>
                <div class="text-[10px] sm:text-xs text-muted-foreground mt-1">
                  60% of 10h goal
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Section -->
    <section class="py-8 border-b border-border/50">
      <div class="max-w-5xl mx-auto px-4">
        <p class="text-center text-muted-foreground text-sm">
          Used by <span class="font-medium text-foreground">engineers worldwide</span>
        </p>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-12 sm:py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <h2 class="animate-on-scroll text-xl sm:text-2xl md:text-3xl font-semibold text-center mb-3 sm:mb-4">
          Everything you need to work with more intention
        </h2>
        <p class="animate-on-scroll text-sm sm:text-base text-muted-foreground text-center mb-8 sm:mb-12 max-w-2xl mx-auto px-2">
          It's not about working more. It's about working with clarity.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">

          <!-- Feature 1 - Heatmap Calendar -->
          <div class="animate-on-scroll">
            <div class="group relative bg-card rounded-xl p-6 border border-border hover:border-[#c17a5c]/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg overflow-hidden h-full">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#c17a5c] to-amber-500"></div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-[#c17a5c]/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#c17a5c]">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-semibold text-lg mb-2">Visualize your effort day by day</h3>
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    See your work patterns at a glance with a heatmap calendar. Know your productive days.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Feature 2 - Deep Work -->
          <div class="animate-on-scroll">
            <div class="group relative bg-card rounded-xl p-6 border border-border hover:border-purple-500/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg overflow-hidden h-full">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-purple-500 to-pink-500"></div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500">
                    <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                    <path d="M3 3v5h5"/>
                    <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
                    <path d="M16 16h5v5"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-semibold text-lg mb-2">Measure deep work, not seat time</h3>
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    Track focused work sessions separately from meetings and context-switching. Know your real output.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Feature 3 - Weekly Goals -->
          <div class="animate-on-scroll">
            <div class="group relative bg-card rounded-xl p-6 border border-border hover:border-green-500/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg overflow-hidden h-full">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-green-500 to-emerald-500"></div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500">
                    <circle cx="12" cy="12" r="10"/>
                    <circle cx="12" cy="12" r="6"/>
                    <circle cx="12" cy="12" r="2"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-semibold text-lg mb-2">Set targets and stay on track</h3>
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    Define weekly hour goals, track progress in real time, and build consistency over sprints.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Feature 4 - Patterns Over Time -->
          <div class="animate-on-scroll">
            <div class="group relative bg-card rounded-xl p-6 border border-border hover:border-primary/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg overflow-hidden h-full">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-amber-500"></div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-semibold text-lg mb-2">Understand your patterns over time</h3>
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    See which tasks and projects consume your time. Use data to improve your work habits.
                  </p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-10 sm:py-12 md:py-16 bg-muted/30">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h3 class="animate-on-scroll text-lg sm:text-xl md:text-2xl font-semibold mb-3 sm:mb-4">
          Ready to take ownership of your time?
        </h3>
        <p class="animate-on-scroll text-sm sm:text-base text-muted-foreground mb-4 sm:mb-6 px-2">
          Start for free and see the difference of measuring your real focus.
        </p>
        <a href="/login" class="animate-on-scroll inline-block">
          <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 rounded-md px-6 text-sm sm:text-base">
            Start tracking for free
          </button>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-6 sm:py-8 border-t border-border">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center gap-4 md:flex-row md:justify-between">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 sm:h-5 sm:w-5 text-primary">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span class="font-medium text-sm sm:text-base">ShipHours</span>
          </div>
          <div class="flex gap-4 sm:gap-6 text-xs sm:text-sm text-muted-foreground">
            <a href="/terms" class="hover:text-foreground transition-colors">
              Terms of Use
            </a>
            <a href="/privacy" class="hover:text-foreground transition-colors">
              Privacy Policy
            </a>
            <a href="/blog" class="hover:text-foreground transition-colors">
              Blog
            </a>
          </div>
          <div class="text-xs sm:text-sm text-muted-foreground">
            &copy; {currentYear} ShipHours
          </div>
        </div>
      </div>
    </footer>
  </div>

  <style>
    /* Scroll animations */
    .animate-on-scroll {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .animate-on-scroll.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    // Intersection Observer for scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  </script>
</BaseLayout>
